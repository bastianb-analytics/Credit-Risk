def build_gain_table(y_true, y_prob, n_bins=100):
    df = pd.DataFrame({
        "y_true": y_true,
        "y_prob": y_prob
    }).sort_values("y_prob", ascending=False).reset_index(drop=True)

    df["cum_total"] = np.arange(1, len(df) + 1)
    df["cum_pct_population"] = df["cum_total"] / len(df)

    df["cum_positives"] = df["y_true"].cumsum()
    total_positives = df["y_true"].sum()
    df["cum_pct_positives"] = df["cum_positives"] / total_positives

    baseline_rate = total_positives / len(df)
    df["lift"] = df["cum_pct_positives"] / df["cum_pct_population"]

    return df, baseline_rate

