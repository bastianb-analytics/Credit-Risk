policy_recall = threshold_df[threshold_df["recall"] >= 0.40].iloc[0]
print("Recall above 40%:\n", policy_recall)
print()

# In this case, operationally infeasible
# You would have to review all portfolios, so this is discarded
# Values are very variable with extremes

## Here we apply the method: OPERATIONAL CAPACITY
# We say: "I can only review 10% of the customers"

policy_capacity = threshold_df[
    threshold_df["predicted_positive_rate"] <= 0.10
].iloc[-1]

print("Predictive rate below 10%:\n", policy_capacity)
print()

# Precision is very good, but we capture almost no defaulters
# Useful if intervention cost is very high

## Here we use: MAXIMUM F1 (technical reference)

threshold_df["f1"] = (
    2 * threshold_df["precision"] * threshold_df["recall"] /
    (threshold_df["precision"] + threshold_df["recall"])
)

policy_f1 = threshold_df.loc[threshold_df["f1"].idxmax()]
print("Max F1: \n", policy_f1)

# This is more realistic for the following reasons:
# Reasonable recall
# Precision well above the baseline
# Manageable population to intervene
# This is where we want to operate

# Here we will do the following example:
# Benefit for detecting a true positive: 100
# Cost for a false positive: 10

benefit_tp = 100
cost_fp = 10

threshold_df["profit"] = (
    threshold_df["tp"] * benefit_tp
    - threshold_df["fp"] * cost_fp
)

best_profit_row = threshold_df.loc[threshold_df["profit"].idxmax()]
best_profit_row

# Create the profit curve to confirm that the maximum
# is reached within the range of x-axis values
# and not at the extremes

plt.figure(figsize=(7,5))
plt.plot(threshold_df["threshold"], threshold_df["profit"])
plt.xlabel("Threshold")
plt.ylabel("Profit")
plt.title("Profit Curve")
plt.grid(True)
plt.show()

