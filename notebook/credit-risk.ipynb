def ks_table(y_true, y_prob, n_bins=10):
    df = pd.DataFrame({
        "y_true": y_true,
        "y_prob": y_prob
    }).sort_values("y_prob", ascending=False).reset_index(drop=True)

    # Create deciles by ranking
    df["decile"] = pd.qcut(
        df.index + 1,
        q=n_bins,
        labels=False
    )

    ks_df = df.groupby("decile").agg(
        total=("y_true", "count"),
        positives=("y_true", "sum")
    ).sort_index().reset_index()

    ks_df["negatives"] = ks_df["total"] - ks_df["positives"]

    # Correct cumulative counts (from high risk â low risk)
    ks_df["cum_pos"] = ks_df["positives"].cumsum()
    ks_df["cum_neg"] = ks_df["negatives"].cumsum()

    ks_df["cum_pos_rate"] = ks_df["cum_pos"] / ks_df["positives"].sum()
    ks_df["cum_neg_rate"] = ks_df["cum_neg"] / ks_df["negatives"].sum()

    ks_df["ks"] = ks_df["cum_pos_rate"] - ks_df["cum_neg_rate"]

    ks_value = ks_df["ks"].abs().max()

    return ks_df, ks_value

ks_df, ks_value = ks_table(y_test, y_prob)

