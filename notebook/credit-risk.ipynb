# This, on one hand, calculates the model's precision at each threshold,
# recall at each threshold,
# and the probability cutoffs evaluated where the array sizes differ by one
# Sort y_prob from highest to lowest, shift the threshold, and calculate
# TP = True Positive, FP = False Positive, FN = False Negative
# From this we obtain precision and recall
precision, recall, thresholds = precision_recall_curve(y_test, y_prob)

# Create a dataframe with the desired data:
# Threshold, Recall, Precision. We use [:-1] because the array sizes differ
pr_df = pd.DataFrame({
    "threshold": thresholds,
    "precision": precision[:-1],
    "recall": recall[:-1]
})
pr_df

# Here the numbers mean:
# we start at 0.01
# go up to 0.5
# and between these values, only 100 points are counted
# we stop at 0.5 for safety, though sometimes 0.3 is used

threshold_grid = np.linspace(0.01, 0.5, 100)

# On the other hand, this row is an empty list we will use to store the data
rows = []

for t in threshold_grid:
    # Here the variable that will change is t among the 100 values
    # defined above
    y_pred_t = (y_prob >= t).astype(int)

    # Define true positives, false positives, and false negatives
    # TP = cases where y_test and y_pred both equal 1
    # FP = cases where y_test is 0 but prediction reads as 1
    # FN = cases where y_test is 1 but prediction reads as 0
    tp = ((y_pred_t == 1) & (y_test == 1)).sum()
    fp = ((y_pred_t == 1) & (y_test == 0)).sum()
    fn = ((y_pred_t == 0) & (y_test == 1)).sum()

    # Calculate precision for the current threshold t
    # using the standard formula: true positives / all predicted positives
    precision_t = tp / (tp + fp) if (tp + fp) > 0 else 0
    # Calculate recall: true positives / (true positives + false negatives)
    recall_t = tp / (tp + fn) if (tp + fn) > 0 else 0

    # Append the computed values to rows in order of threshold t
    rows.append({
        "threshold": t,
        "precision": precision_t,
        "recall": recall_t,
        "tp": tp,
        "fp": fp
    })

# Now create the threshold dataframe with the columns defined above
# using the rows list
threshold_df = pd.DataFrame(rows)
threshold_df

